# OpenRouter API設定

# [必須] OpenRouter API キー
# https://openrouter.ai で取得してください
OPENROUTER_API_KEY=sk-xxx-xxxxxxxxxxxxxxxxxxxxxx

# [推奨] 第一候補のモデル名
# 無料枠を使う場合は :free サフィックスを付けてください
OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free

# [推奨] フォールバックモデル（カンマ区切り）
# 第一選択肢が利用不可の場合にも使用されます
OPENROUTER_FALLBACK_MODELS=openai/gpt-oss-120b:free

# [オプション] 再試行回数（レート制限時）
# デフォルト: 1（再試行なし）
# 無料枠の場合は 2〜3 を推奨
AI_JOURNAL_MAX_RETRIES=1

# [オプション] 最大出力トークン
# 1日ごとの生成時に反映されます
# デフォルト: 1500（日別モード）
AI_JOURNAL_MAX_OUTPUT_TOKENS=1500

# [オプション] サイト情報（トラッキング用）
# OpenRouter に送信するサイト URL
OPENROUTER_SITE_URL=https://myapp.example.com

# [オプション] サイト名（トラッキング用）
OPENROUTER_SITE_NAME=MyApp
